{
  "name": "dbi-backend",
  "version": "0.3.138",
  "description": "Database importer backend",
  "type": "module",
  "main": "app.ts",
  "scripts": {
    "test:build": "tsc -p tsconfig.node-test.json",
    "test:run": "node dist-test/test/node-runner.js dist-test/src/routes/row.test.js dist-test/src/routes/table.test.js dist-test/src/routes/tables.test.js dist-test/src/routes/user.test.js",
    "test": "npm run test:build && npm run test:run",
    "dev": "nodemon -r dotenv/config ./src/index.ts",
    "comp": "tsc --declaration",
    "preprod": "tsc && node -r dotenv/config ./dist/index.js",
    "start": "node dist/index.js",
    "startdev": "tsc && node -r dotenv/config dist/index.js"
  },
  "keywords": [
    "MSSQL",
    "Import",
    "Database",
    "CSV",
    "Excel",
    "Copy&Paste"
  ],
  "author": "Michael Ronge",
  "license": "Apache-2.0",
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/express-ntlm": "^2.3.3",
    "@types/mssql": "^12.3.0",
    "@types/node": "^26.1.1",
    "@types/supertest": "^7.2.1",
    "@types/tsqlstring": "^1.0.2",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "body-parser": "^2.2.0",
    "express": "^5.1.0",
    "express-ntlm": "^2.6.2",
    "express-validator": "^7.0.1",
    "mssql": "^12.0.0",
    "supertest": "^7.2.2",
    "tsqlstring": "^1.0.1"
  },
  "allowScripts": {
    "unrs-resolver@1.12.2": true
  }
}
